{
  "expo": {
    "name": "MABCare",
    "slug": "monoclonalAntibodyTreatmentManagementSystem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D4F5C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.melihburakbagci.mabcare"
    },
    "android": {
      "package": "com.melihburakbagci.mabcare",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D4F5C"
      }
    },
    "scheme": "myapp",
    "plugins": [
      "expo-router",
      "./plugins/withDisableFlipper",
      "./plugins/withRemoveFlipperFromMainApplication"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9b5dc8d5-8165-4a3d-a592-f46dba0ecdf9"
      }
    }
  }
}
